# Switches every service factory between Mock* and Api* implementations.
# - mock: in-memory mock data with simulated latency and occasional errors (default)
# - api : stubs that throw not_implemented until the real backend is wired up
NEXT_PUBLIC_DATA_SOURCE=mock

# Selects the AI provider when NEXT_PUBLIC_DATA_SOURCE=api.
# - anthropic : AnthropicAIService (stub)
# - openai    : OpenAIService (stub)
# Ignored when NEXT_PUBLIC_DATA_SOURCE=mock (the mock AI service is always used).
NEXT_PUBLIC_AI_PROVIDER=anthropic

# OpenAI API key — server-side only, do NOT prefix with NEXT_PUBLIC_.
# Required for the "AI Format" button in the summary editor.
OPENAI_API_KEY=
